<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.mycompany.horender.Controller.CreditosController"
           styleClass="sub-screen-root"
           stylesheets="@style.css">
    <VBox alignment="CENTER" spacing="20" styleClass="sub-screen-content">
        <Label text="Créditos"
               styleClass="title"/>
        <Label text="Desenvolvido por: Seu Nome&#10;Arte: Sua Equipe&#10;Música: Seu Compositor"
               styleClass="text-body"/>
        <Button text="Voltar"
                onAction="#onVoltar"
                styleClass="button"/>
    </VBox>
</StackPane>