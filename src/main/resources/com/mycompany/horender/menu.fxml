<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mycompany.horender.Controllers.MenuController"
            style="-fx-background-color: #1E1E1E;">
    
            <!-- Placeholder para a arte de fundo em pixel art (estática ou animada)
    <ImageView fx:id="backgroundImage"
               preserveRatio="false"
               smooth="false"
               StackPane.alignment="CENTER"
               style="-fx-opacity: 0.3;">
         Substitua o caminho abaixo pelo recurso real (ex.: /assets/background_pixel_art.gif)
        <image>
            <javafx.scene.image.Image url="/assets/placeholder_background.png" backgroundLoading="true" />
        </image>
    </ImageView>
            -->
    <!-- Camada de conteúdo -->
    <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
                minHeight="-Infinity" minWidth="-Infinity"
                prefHeight="720" prefWidth="1280">

        <!-- Título no canto superior esquerdo -->
        <Label text="Horender"
               AnchorPane.topAnchor="30.0"
               AnchorPane.leftAnchor="30.0"
               style="-fx-font-family: 'Impact'; -fx-font-size: 48; -fx-text-fill: #DC143C;"/>

        <!-- Botões no canto inferior esquerdo -->
        <VBox spacing="15"
              AnchorPane.bottomAnchor="40.0"
              AnchorPane.leftAnchor="30.0"
              alignment="CENTER_LEFT">
            <Button text="Jogar"
                    onAction="#onJogar"
                    style="-fx-background-color: #2A2A2A; -fx-text-fill: #C0C0C0; -fx-font-size: 18; -fx-min-width: 150;"/>
            <Button text="Ranking"
                    onAction="#onRanking"
                    style="-fx-background-color: #2A2A2A; -fx-text-fill: #C0C0C0; -fx-font-size: 18; -fx-min-width: 150;"/>
            <Button text="Créditos"
                    onAction="#onCreditos"
                    style="-fx-background-color: #2A2A2A; -fx-text-fill: #C0C0C0; -fx-font-size: 18; -fx-min-width: 150;"/>
        </VBox>
    </AnchorPane>
</StackPane>
